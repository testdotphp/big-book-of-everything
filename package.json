{
  "name": "portal-template",
  "version": "1.2.1",
  "description": "A self-hosted web portal with configurable sidebar navigation, optional OIDC auth, and a built-in Big Book of Everything family information organizer.",
  "keywords": [
    "portal",
    "dashboard",
    "sveltekit",
    "self-hosted",
    "oidc",
    "homelab"
  ],
  "license": "MIT",
  "author": "TJ Bennett",
  "repository": {
    "type": "git",
    "url": "https://github.com/testdotphp/big-book-of-everything.git"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "npm run build && electron electron/main.cjs",
    "electron:build": "npm run build && electron-builder",
    "electron:package": "npm run build && node scripts/prepare-electron.cjs && electron-builder",
    "electron:rebuild": "node scripts/prepare-electron.cjs"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@sveltejs/adapter-node": "^5.0.0",
    "@sveltejs/kit": "2.20.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.9",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "svelte": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@auth/core": "^0.37.0",
    "@auth/sveltekit": "^1.7.0",
    "@aws-sdk/client-s3": "^3.1008.0",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "lucide-svelte": "^0.468.0"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.testdotphp.big-book-of-everything",
    "productName": "Big Book of Everything",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build",
        "to": "server/build"
      },
      {
        "from": "drizzle",
        "to": "server/drizzle"
      },
      {
        "from": "configs/book-structure.json",
        "to": "server/configs/book-structure.json"
      },
      {
        "from": ".electron-staging/node_modules",
        "to": "server/node_modules"
      },
      {
        "from": ".electron-staging/server-package.json",
        "to": "server/package.json"
      }
    ],
    "generateUpdatesFilesForAllChannels": false,
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "Big-Book-of-Everything-${version}-${arch}.${ext}",
      "category": "public.app-category.productivity",
      "icon": "electron/icons/icon.icns"
    },
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "Big-Book-of-Everything-${version}-portable.${ext}",
      "icon": "electron/icons/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "artifactName": "Big-Book-of-Everything-${version}.${ext}",
      "category": "Utility",
      "icon": "electron/icons"
    },
    "dmg": {
      "writeUpdateInfo": false,
      "background": null,
      "title": "Big Book of Everything",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
