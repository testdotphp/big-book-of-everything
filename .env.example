# Portal Configuration
# Path to your portal config JSON (sidebar items, theme, etc.)
PORTAL_CONFIG_PATH=portal.config.json

# Origin URL (required for HTTPS deployments)
ORIGIN=http://localhost:3000

# Big Book of Everything (optional — omit to disable)
# BOOK_DB_PATH=./data/book.db

# OIDC Authentication (optional — omit all to run without auth)
# Works with any OIDC provider: Authentik, Keycloak, Auth0, Google, etc.
# OIDC_ISSUER=https://your-oidc-provider/.well-known/openid-configuration
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# AUTH_SECRET=generate-with-openssl-rand-base64-32

# Custom CA Certificate (optional — for self-signed HTTPS)
# CA_CERT_PATH=/path/to/ca.crt
# NODE_EXTRA_CA_CERTS=/path/to/ca.crt
